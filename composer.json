{
  "name": "devinci-it/shadow-auth",
  "description": "Lightweight file-based PHP authentication library with optional TOTP.",
  "type": "library",
  "license": "MIT",
  "bin": [
    "bin/shadow-auth-publish-demo",
    "bin/shadow-auth-serve-demo",
    "bin/shadow-auth-tag-release"
  ],
  "require": {
    "php": ">=8.1"
  },
  "scripts": {
    "publish-demo": "@php vendor/bin/shadow-auth-publish-demo",
    "publish-demo-force": "@php vendor/bin/shadow-auth-publish-demo --force",
    "publish-endpoints": "@php vendor/bin/shadow-auth-publish-demo --endpoints",
    "publish-endpoints-force": "@php vendor/bin/shadow-auth-publish-demo --endpoints --force",
    "serve-demo": "@php vendor/bin/shadow-auth-serve-demo",
    "release-tag": "@php bin/shadow-auth-tag-release",
    "release-tag-push": "@php bin/shadow-auth-tag-release --push"
  },
  "autoload": {
    "psr-4": {
      "DevinciIT\\ShadowAuth\\": "src/",
      "Shadow\\": "src/Shadow/"
    }
  }
}
